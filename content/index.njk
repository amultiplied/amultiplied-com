---js
const eleventyNavigation = {
	key: "Home",
	order: 1
};
---
{% set allPosts = collections.posts | reverse %}
{% set latestPost = allPosts[0] %}

{% if latestPost %}
<article class="featured-post">
	<h2 class="featured-post-title"><a href="{{ latestPost.url }}">{{ latestPost.data.title }}</a></h2>
	<time class="featured-post-date" datetime="{{ latestPost.date | htmlDateString }}">{{ latestPost.date | readableDate }}</time>
	{{ latestPost.templateContent | safe }}
</article>
{% endif %}

<p class="all-posts-heading">All Posts</p>
<ul class="postlist">
{%- for post in allPosts %}
	<li class="postlist-item{% if post.url == page.url %} postlist-item-active{% endif %}">
		<time class="postlist-date" datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate("LLL d, yyyy") }}</time>
		<a href="{{ post.url }}" class="postlist-link">{% if post.data.title %}{{ post.data.title }}{% else %}<code>{{ post.url }}</code>{% endif %}</a>
	</li>
{%- endfor %}
</ul>
